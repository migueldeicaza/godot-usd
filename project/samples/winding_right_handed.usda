#usda 1.0
(
    defaultPrim = "WindingTriangle"
    metersPerUnit = 1
    upAxis = "Y"
)

def Mesh "WindingTriangle"
{
    uniform token orientation = "rightHanded"
    int[] faceVertexCounts = [3]
    int[] faceVertexIndices = [0, 1, 2]
    point3f[] points = [(-0.5, -0.5, 0), (0.5, -0.5, 0), (0.0, 0.5, 0)]
    uniform token subdivisionScheme = "none"
}
