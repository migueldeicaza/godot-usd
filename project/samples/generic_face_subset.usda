#usda 1.0
(
    defaultPrim = "Root"
    upAxis = "Y"
)

def Xform "Root"
{
    def Mesh "Panel" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        int[] faceVertexCounts = [3, 3, 3, 3]
        int[] faceVertexIndices = [0, 1, 2, 1, 3, 2, 1, 4, 3, 4, 5, 3]
        point3f[] points = [(0, 0, 0), (1, 0, 0), (0, 1, 0), (1, 1, 0), (2, 0, 0), (2, 1, 0)]
        rel material:binding = </Root/Looks/Base>

        def GeomSubset "Corners"
        {
            uniform token elementType = "face"
            uniform token familyName = "selection"
            int[] indices = [0, 3]
        }
    }

    def Scope "Looks"
    {
        def Material "Base"
        {
            token outputs:surface.connect = </Root/Looks/Base/Preview.outputs:surface>

            def Shader "Preview"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.7, 0.7, 0.7)
                token outputs:surface
            }
        }
    }
}
