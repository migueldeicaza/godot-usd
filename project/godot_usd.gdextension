[configuration]

entry_symbol = "godot_usd_library_init"
compatibility_minimum = "4.3"
reloadable = true

[libraries]

macos.debug = "res://bin/libgodot_usd.macos.template_debug.arm64.dylib"
macos.release = "res://bin/libgodot_usd.macos.template_release.arm64.dylib"
macos.debug.arm64 = "res://bin/libgodot_usd.macos.template_debug.arm64.dylib"
macos.release.arm64 = "res://bin/libgodot_usd.macos.template_release.arm64.dylib"
